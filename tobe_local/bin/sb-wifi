#!/bin/bash

name=$(iw dev wlan0 link | grep SSID | cut -d' ' -f2- | sed 's/\\x20//g')
dBm=$(iw dev wlan0 link | grep signal | awk '{print $2}')
name_length=20

if [[ -z "${dBm// }" ]]; then
    signal=0
    name=""
else
    signal=" $(( ($dBm + 110) * 100 / 80 ))"
    (( $signal < 0 )) && signal=0
    (( $signal > 100 )) && signal=" 100"
fi

if [ ${#name} -gt $name_length ]; then
    name="${name:0:$name_length}..."
fi

echo "$name$signal%"
