#!/bin/bash

name=$(iw dev wlan0 link | grep SSID | cut -d' ' -f2-)
dBm=$(iw dev wlan0 link | grep signal | awk '{print $2}')

if [[ -z "${dBm// }" ]]; then
    signal=0
    name=""
else
    signal=" $(( ($dBm + 110) * 100 / 80 ))"
    (( $signal < 0 )) && signal=0
    (( $signal > 100 )) && signal=" 100"
fi
echo "$name$signal%"
