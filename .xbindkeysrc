# increase volume
"chg-vol +5 && kill -44 $(pidof dwmblocks)"
   XF86AudioRaiseVolume

# decrease volume
"chg-vol -5 && kill -44 $(pidof dwmblocks)"
   XF86AudioLowerVolume

# mute volume
"pactl set-sink-mute @DEFAULT_SINK@ toggle && kill -44 $(pidof dwmblocks)"
   XF86AudioMute

# mute microphone
"pactl set-source-mute @DEFAULT_SOURCE@ toggle"
   XF86AudioMicMute

# increase brightness
"chg-brite +5 && kill -45 $(pidof dwmblocks)"
   XF86MonBrightnessUp

# decrease brightness
"chg-brite -5 && kill -45 $(pidof dwmblocks)"
   XF86MonBrightnessDown

# suspend
"loginctl lock-session && sleep 0.5 && systemctl suspend"
    Mod4 + Shift + l

# screenshot
"maim -s ~/Media/Screenshots/$(date +%Y-%m-%d_%T).png"
    Mod4 + Shift + s 

# classroom
"firefox https://classroom.google.com/u/1/"
   Mod4 + c

# open gmail inbox - nuces
"https://mail.google.com/mail/u/1/#inbox"
   Mod4 + m

# launch whatsapp web
"firefox https://web.whatsapp.com"
   Mod4 + w
